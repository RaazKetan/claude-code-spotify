{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/activate.py\"; exit 0",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
